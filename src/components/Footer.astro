---
const year = new Date().getFullYear();
---
<footer class="text-sm text-[color:var(--color-ink-muted)]" style="border-top: 1px solid var(--color-line);">
  <div class="mx-auto flex flex-wrap items-center justify-between gap-4 px-6 py-6"
       style="max-width: var(--max-page);">
    <p>© {year} · Behnaz · Made with care in Aachen</p>
    <div class="flex items-center gap-4">
      <a href="mailto:hello@behnaz.example" class="nav-link">Email</a>
      <a href="https://www.linkedin.com/" class="nav-link" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://github.com/" class="nav-link" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</footer>
