---
import Tag from "./Tag.astro";

interface Props {
  href: string;
  title: string;
  description?: string;
  date: string | Date;
  tags?: string[];
  emoji?: string;
}

const { href, title, description, date, tags = [], emoji } = Astro.props;
const dateStr = new Date(date).toLocaleDateString("en-GB", {
  day: "numeric",
  month: "short",
  year: "numeric",
});
---
<a href={href} class="card block">
  <div class="mb-2 flex items-center gap-3 text-xs text-[color:var(--color-ink-muted)]">
    <span>{dateStr}</span>
    {tags.length > 0 && <span>·</span>}
    {tags.map((t) => <Tag name={t} />)}
  </div>
  <h3 class="mb-1.5 text-xl">
    {emoji && <span class="mr-1.5">{emoji}</span>}
    {title}
  </h3>
  {description && (
    <p class="text-[0.95rem] leading-relaxed text-[color:var(--color-ink-soft)]">
      {description}
    </p>
  )}
</a>
