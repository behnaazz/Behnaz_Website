---
const path = Astro.url.pathname;
const isActive = (p: string) => path === p || (p !== "/" && path.startsWith(p));

const links = [
  { href: "/", label: "home" },
  { href: "/about", label: "about" },
  { href: "/writing", label: "writing" },
  { href: "/projects", label: "projects" },
  { href: "/gallery", label: "gallery" },
  { href: "/cv", label: "cv" },
];
---
<header class="mx-auto max-w-3xl px-6 pt-8">
  <div class="flex items-center justify-between gap-6">
    <a href="/" class="group flex items-center gap-2.5">
      <span
        class="grid h-9 w-9 place-items-center rounded-full bg-[color:var(--color-coral-soft)] text-[color:var(--color-ink)] transition-transform duration-300 group-hover:rotate-12"
        style="font-family: var(--font-serif); font-weight: 600;"
      >
        b
      </span>
      <span class="text-lg" style="font-family: var(--font-serif); font-weight: 500;">
        behnaz
      </span>
    </a>
    <nav class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
      {links.slice(1).map((l) => (
        <a
          href={l.href}
          class:list={["nav-link", { "is-active": isActive(l.href) }]}
        >
          {l.label}
        </a>
      ))}
    </nav>
  </div>
</header>
