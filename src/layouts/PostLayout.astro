---
import BaseLayout from "./BaseLayout.astro";
import Tag from "../components/Tag.astro";

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    date: string | Date;
    tags?: string[];
    emoji?: string;
  };
}

const { frontmatter } = Astro.props;
const dateObj = new Date(frontmatter.date);
const dateStr = dateObj.toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---
<BaseLayout title={`${frontmatter.title} — Behnaz`} description={frontmatter.description}>
  <article class="rise">
    <div class="mb-3 flex items-center gap-3 text-sm text-[color:var(--color-ink-soft)]">
      <span>{dateStr}</span>
      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <span class="text-[color:var(--color-ink-muted)]">·</span>
      )}
      {frontmatter.tags?.map((t) => <Tag name={t} />)}
    </div>
    <h1 class="mb-3">
      {frontmatter.emoji && <span class="mr-2">{frontmatter.emoji}</span>}
      {frontmatter.title}
    </h1>
    {frontmatter.description && (
      <p class="mb-10 text-lg text-[color:var(--color-ink-soft)] italic" style="font-family: var(--font-serif);">
        {frontmatter.description}
      </p>
    )}
    <div class="prose">
      <slot />
    </div>
    <div class="mt-16 border-t border-[color:var(--color-line)] pt-8">
      <a href="/writing" class="nav-link text-sm text-[color:var(--color-ink-soft)]">
        ← back to writing
      </a>
    </div>
  </article>
</BaseLayout>
