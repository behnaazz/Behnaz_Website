---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---
<BaseLayout title="Behnaz — a small corner of the internet">
  <section class="rise mb-16">
    <p class="mb-4 text-sm uppercase tracking-[0.2em] text-[color:var(--color-coral)]">
      hello, world
    </p>
    <h1 class="mb-6">
      i'm <span class="squiggle">behnaz</span> —
      <br />a researcher, baker,<br />and tinkerer of small things.
    </h1>
    <p class="max-w-prose text-lg leading-relaxed text-[color:var(--color-ink-soft)]">
      currently working on deep learning for medical thermal imaging at
      <a href="https://www.medit.hia.rwth-aachen.de/" class="underline decoration-[color:var(--color-coral)] decoration-2 underline-offset-4 hover:text-[color:var(--color-coral)]">
        rwth aachen
      </a>.
      this site is a quiet little garden where i collect what i'm reading,
      cooking, building, and thinking about.
    </p>
    <div class="mt-8 flex flex-wrap gap-3 text-sm">
      <a href="/about" class="rounded-full bg-[color:var(--color-coral)] px-5 py-2.5 font-medium text-white shadow-[var(--shadow-cozy)] transition hover:scale-[1.02] hover:bg-[color:var(--color-ink)]">
        about me →
      </a>
      <a href="/writing" class="rounded-full border border-[color:var(--color-line)] bg-white px-5 py-2.5 font-medium transition hover:border-[color:var(--color-coral)] hover:text-[color:var(--color-coral)]">
        latest writing
      </a>
    </div>
  </section>

  <section class="rise rise-delay-2 mb-16">
    <div class="mb-6 flex items-baseline justify-between">
      <h2>recent</h2>
      <a href="/writing" class="nav-link text-sm text-[color:var(--color-ink-soft)]">all posts →</a>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {posts.map((p) => (
        <PostCard
          href={`/writing/${p.id}`}
          title={p.data.title}
          description={p.data.description}
          date={p.data.date}
          tags={p.data.tags}
          emoji={p.data.emoji}
        />
      ))}
    </div>
  </section>

  <section class="rise rise-delay-3 mb-12">
    <h2 class="mb-6">a few things i love</h2>
    <div class="grid gap-3 sm:grid-cols-2">
      {[
        { emoji: "🔬", text: "thermal imaging & spectroscopy" },
        { emoji: "🥐", text: "buttery laminated pastries" },
        { emoji: "📓", text: "field notes & marginalia" },
        { emoji: "🌿", text: "long walks in the öcher wald" },
        { emoji: "🎞️", text: "film photography" },
        { emoji: "🧶", text: "amigurumi & slow crafts" },
      ].map((item) => (
        <div class="flex items-center gap-3 rounded-[var(--radius-soft)] border border-[color:var(--color-line)] bg-white px-4 py-3 text-[0.95rem]">
          <span class="text-xl">{item.emoji}</span>
          <span>{item.text}</span>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
