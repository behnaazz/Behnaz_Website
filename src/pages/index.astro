---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const projects = (await getCollection("projects"))
  .sort((a, b) =>
    a.data.featured === b.data.featured
      ? b.data.year.localeCompare(a.data.year)
      : a.data.featured ? -1 : 1
  );

const recentPosts = posts.slice(0, 4);
const recentProjects = projects.slice(0, 3);

const fmt = (d: string | Date) =>
  new Date(d).toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "2-digit" });
---
<BaseLayout title="Behnaz — a small corner of the internet">
  <section class="rise mb-12">
    <p class="eyebrow mb-4">Hello</p>
    <h1 class="mb-5">
      I'm <span class="accent-name">Behnaz</span> —
      <br />a researcher, baker,
      <br />and tinkerer of small things.
    </h1>
    <p class="max-w-prose text-[1.02rem] leading-relaxed text-[color:var(--color-ink-soft)]">
      Currently working on deep learning for medical thermal imaging at
      <a
        href="https://www.medit.hia.rwth-aachen.de/"
        class="underline decoration-[color:var(--color-accent)] decoration-2 underline-offset-4 hover:text-[color:var(--color-accent)]"
      >RWTH Aachen</a>.
      This site is a quiet little garden where I collect what I'm reading,
      cooking, building, and thinking about.
    </p>
  </section>

  <section class="rise rise-delay-2 mb-12">
    <p class="eyebrow mb-4">Directory</p>
    <h2 class="mb-6" style="font-size: 1.45rem;">Where to find things</h2>

    <div class="directory">
      <article class="dir-card">
        <div class="dir-card-head">
          <h3 class="dir-card-title">Writing</h3>
          <a href="/writing" class="dir-card-link">All posts →</a>
        </div>
        <p class="dir-card-desc">
          A slow-growing collection — half-finished thoughts, recipes I keep
          coming back to, notes from papers, and the occasional small essay.
        </p>
        <div class="dir-card-list">
          {recentPosts.map((p) => (
            <a href={`/writing/${p.id}`}>
              <span class="ddate">{fmt(p.data.date)}</span>
              <span>{p.data.title}</span>
            </a>
          ))}
        </div>
      </article>

      <article class="dir-card">
        <div class="dir-card-head">
          <h3 class="dir-card-title">Projects</h3>
          <a href="/projects" class="dir-card-link">All projects →</a>
        </div>
        <p class="dir-card-desc">
          Research, code, and side experiments — somewhere between optics,
          machine learning, and a useful little tool.
        </p>
        <div class="dir-card-list">
          {recentProjects.map((p) => (
            <a href="/projects">
              <span class="ddate">{p.data.year}</span>
              <span>{p.data.title}</span>
            </a>
          ))}
        </div>
      </article>

      <article class="dir-card">
        <div class="dir-card-head">
          <h3 class="dir-card-title">About &amp; CV</h3>
        </div>
        <p class="dir-card-desc">
          The short story: data scientist, photonics and machine learning,
          somewhere on a long walk between research and the kitchen.
        </p>
        <div class="dir-card-list">
          <a href="/about">
            <span class="ddate">Intro</span>
            <span>About me — the long version</span>
          </a>
          <a href="/cv">
            <span class="ddate">CV</span>
            <span>Curriculum vitae (with PDF)</span>
          </a>
        </div>
      </article>

      <article class="dir-card">
        <div class="dir-card-head">
          <h3 class="dir-card-title">Gallery</h3>
          <a href="/gallery" class="dir-card-link">View all →</a>
        </div>
        <p class="dir-card-desc">
          Sketches, film photos, and the occasional thermal portrait.
          Updated when I remember to.
        </p>
        <div class="dir-card-list">
          <a href="/gallery">
            <span class="ddate">Visual</span>
            <span>Small visual things, kept loose</span>
          </a>
        </div>
      </article>
    </div>
  </section>

  <section class="rise rise-delay-3 mb-12">
    <p class="eyebrow mb-4">A small inventory</p>
    <h2 class="mb-5" style="font-size: 1.35rem;">Things I love</h2>
    <div class="grid gap-2 sm:grid-cols-2">
      {[
        "Thermal imaging and spectroscopy",
        "Buttery laminated pastries",
        "Field notes and marginalia",
        "Long walks in the Aachener Wald",
        "Film photography",
        "Amigurumi and slow crafts",
      ].map((text) => (
        <div class="flex items-center gap-3 rounded-[var(--radius-soft)] border border-[color:var(--color-line)] bg-[color:var(--color-paper)] px-3.5 py-2.5 text-[0.92rem]">
          <span class="text-[color:var(--color-ink-muted)]">·</span>
          <span>{text}</span>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
