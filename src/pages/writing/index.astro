---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Tag from "../../components/Tag.astro";
import { getCollection } from "astro:content";

const all = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tagSet = new Set<string>();
all.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));
const tags = Array.from(tagSet).sort();

// group by year for tidy index
const byYear = new Map<number, typeof all>();
for (const p of all) {
  const y = new Date(p.data.date).getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = Array.from(byYear.keys()).sort((a, b) => b - a);

const fmt = (d: string | Date) =>
  new Date(d).toLocaleDateString("en-GB", { day: "2-digit", month: "short" });
---
<BaseLayout
  title="Writing — Behnaz"
  description="Thoughts, recipes, notes, and field reports."
>
  <section class="rise">
    <div class="page-head">
      <p class="eyebrow">writing</p>
      <h1>The Garden</h1>
      <p class="lede">
        A slow-growing collection — half-finished thoughts, recipes I keep
        coming back to, notes from papers, and the occasional small essay.
        <strong>{all.length}</strong> entries so far.
      </p>
    </div>

    <div class="mb-8 flex flex-wrap items-center gap-2">
      <span class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-ink-muted)]">Filter</span>
      <a href="/writing" class="tag" data-tag="all">all</a>
      {tags.map((t) => (
        <a
          href={`/writing?tag=${t}`}
          class={`tag tag-${t.toLowerCase()}`}
          data-tag={t.toLowerCase()}
        >
          {t}
        </a>
      ))}
    </div>

    {years.map((y) => (
      <div class="index-group">
        <div class="index-group-title">
          <span>{y}</span>
          <span class="index-group-title-count">{byYear.get(y)!.length} {byYear.get(y)!.length === 1 ? "entry" : "entries"}</span>
        </div>
        <ul class="index-list">
          {byYear.get(y)!.map((p) => (
            <li
              class="post-item"
              data-tags={p.data.tags.map((t) => t.toLowerCase()).join(",")}
            >
              <a href={`/writing/${p.id}`} class="index-row">
                <span class="index-date">{fmt(p.data.date)}</span>
                <span>
                  <span class="index-title">
                    {p.data.emoji && <span class="mr-1.5">{p.data.emoji}</span>}
                    {p.data.title}
                  </span>
                  {p.data.description && (
                    <span class="index-desc">{p.data.description}</span>
                  )}
                </span>
                <span class="index-meta">
                  {p.data.tags.map((t) => <Tag name={t} />)}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>

<script>
  // Simple client-side tag filter via ?tag=foo
  const params = new URLSearchParams(window.location.search);
  const tag = params.get("tag");
  if (tag) {
    document.querySelectorAll<HTMLElement>(".post-item").forEach((el) => {
      const tags = (el.dataset.tags ?? "").split(",");
      el.style.display = tags.includes(tag) ? "" : "none";
    });
    document.querySelectorAll<HTMLElement>("[data-tag]").forEach((el) => {
      if (el.dataset.tag === tag) {
        el.style.outline = "2px solid var(--color-coral)";
        el.style.outlineOffset = "2px";
      }
    });
  }
</script>
