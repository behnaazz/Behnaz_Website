---
import BaseLayout from "../layouts/BaseLayout.astro";

const items = [
  { src: "/gallery/placeholder-1.svg", alt: "soft sunrise study", caption: "Morning study, April" },
  { src: "/gallery/placeholder-2.svg", alt: "thermal scan sketch", caption: "Thermal portrait sketch" },
  { src: "/gallery/placeholder-3.svg", alt: "kitchen still life",  caption: "Kitchen still life" },
  { src: "/gallery/placeholder-4.svg", alt: "wald walk",            caption: "Aachener Wald, golden hour" },
  { src: "/gallery/placeholder-5.svg", alt: "marginalia",           caption: "Thesis marginalia" },
  { src: "/gallery/placeholder-6.svg", alt: "lab notebook",         caption: "Lab notebook page" },
];
---
<BaseLayout title="Gallery — Behnaz" description="Sketches, photos, and small visual experiments.">
  <section class="rise">
    <div class="page-head">
      <p class="eyebrow">gallery</p>
      <h1>Small Visual Things</h1>
      <p class="lede">
        Sketches, film photos, and the occasional thermal portrait. Updated
        when I remember to.
      </p>
    </div>

    <div class="grid grid-cols-2 gap-3 md:grid-cols-3">
      {items.map((it, i) => (
        <figure class={`group rise rise-delay-${(i % 4) + 1}`}>
          <div class="overflow-hidden rounded-[var(--radius-soft)] border border-[color:var(--color-line)] bg-white aspect-[4/5]">
            <img
              src={it.src}
              alt={it.alt}
              loading="lazy"
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
            />
          </div>
          <figcaption class="mt-2 text-xs text-[color:var(--color-ink-muted)]">
            {it.caption}
          </figcaption>
        </figure>
      ))}
    </div>
  </section>
</BaseLayout>
