---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="CV — Behnaz" description="A short version of my CV.">
  <section class="rise">
    <div class="page-head">
      <p class="eyebrow">cv</p>
      <h1>Curriculum Vitae</h1>
      <p class="lede">
        The full PDF is the source of truth — this page is a quick scroll for
        the curious.
        <a
          href="/cv.pdf"
          class="underline decoration-[color:var(--color-accent)] decoration-2 underline-offset-4 hover:text-[color:var(--color-accent)]"
        >Download the full CV (PDF) ↓</a>
      </p>
    </div>

    <div class="space-y-10">
      <div class="index-group">
        <div class="index-group-title"><span>Now</span></div>
        <ul class="index-list">
          <li>
            <div class="index-row">
              <span class="index-date">2026 →</span>
              <span>
                <span class="index-title">Researcher · MedIT, RWTH Aachen</span>
                <span class="index-desc">
                  Deep learning for thermal-infrared medical monitoring (NeuroSys project).
                  Building pipelines, training models in PyTorch, deploying to embedded hardware.
                </span>
              </span>
              <span class="index-meta"></span>
            </div>
          </li>
        </ul>
      </div>

      <div class="index-group">
        <div class="index-group-title"><span>Previously</span></div>
        <ul class="index-list">
          <li>
            <div class="index-row">
              <span class="index-date">'22 — '24</span>
              <span>
                <span class="index-title">Research Assistant · Ruhr University Bochum</span>
                <span class="index-desc">
                  Data-driven decision support for energy technologies — multi-criteria
                  analysis, life-cycle costing, dashboards in Dash and Streamlit.
                </span>
              </span>
              <span class="index-meta"></span>
            </div>
          </li>
          <li>
            <div class="index-row">
              <span class="index-date">Aug '23</span>
              <span>
                <span class="index-title">Intern · Physikalisch-Technische Bundesanstalt (PTB)</span>
                <span class="index-desc">
                  Automated computer-vision pipeline to extract numerical data from
                  measurement images (OpenCV, OOP).
                </span>
              </span>
              <span class="index-meta"></span>
            </div>
          </li>
        </ul>
      </div>

      <div class="index-group">
        <div class="index-group-title"><span>Education</span></div>
        <ul class="index-list">
          <li>
            <div class="index-row">
              <span class="index-date">'21 — '24</span>
              <span>
                <span class="index-title">M.Sc. Lasers &amp; Photonics · Ruhr University Bochum</span>
                <span class="index-desc">
                  Final grade 94/100. Master's thesis on Raman spectroscopy with machine
                  learning for hydrogen impurity quantification (98/100). Awarded best
                  Master's graduate of the year.
                </span>
              </span>
              <span class="index-meta"></span>
            </div>
          </li>
          <li>
            <div class="index-row">
              <span class="index-date">'15 — '20</span>
              <span>
                <span class="index-title">B.Sc. Mechanical Engineering · Ferdowsi University of Mashhad</span>
                <span class="index-desc">Bachelor's thesis on solar-powered water distillation.</span>
              </span>
              <span class="index-meta"></span>
            </div>
          </li>
        </ul>
      </div>

      <div class="index-group">
        <div class="index-group-title"><span>Tools</span></div>
        <div class="flex flex-wrap gap-2 pt-1">
          {["Python", "PyTorch", "scikit-learn", "OpenCV", "pandas", "NumPy", "Matplotlib", "SQL", "MATLAB", "C++", "Git", "HTML / CSS", "SolidWorks", "ANSYS"].map((t) => (
            <span class="rounded-full border border-[color:var(--color-line)] bg-[color:var(--color-paper)] px-3 py-1 text-sm">
              {t}
            </span>
          ))}
        </div>
      </div>

      <div class="index-group">
        <div class="index-group-title"><span>Languages</span></div>
        <ul class="space-y-1 text-[0.95rem] text-[color:var(--color-ink-soft)] pt-1">
          <li>Persian — mother tongue</li>
          <li>English — C2 (TOEFL iBT 113)</li>
          <li>German — C1</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
