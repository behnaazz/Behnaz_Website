---
import BaseLayout from "../../layouts/BaseLayout.astro";
import fs from "node:fs";
import path from "node:path";

const baseDir = path.join(process.cwd(), "public", "gallery", "portugal");

// Optional manual ordering — folders listed here render in this order;
// any other folders are appended alphabetically. Just folder names, lowercase.
// South to north — order in which the trip unfolded
const cityOrder: string[] = ["Tavira", "Lagos", "Lisbon", "Porto"];

// Convert "lagos" → "Lagos", "sao-miguel" → "São Miguel" (rough title-case)
const prettify = (s: string) =>
  s
    .replace(/^\d+[-_]/, "")
    .split(/[-_ ]+/)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");

const isImage = (f: string) => /\.(jpe?g|png|webp)$/i.test(f);

// 1. Find subdirectories of portugal/
const entries = fs.readdirSync(baseDir, { withFileTypes: true });
const subDirs = entries.filter((e) => e.isDirectory()).map((e) => e.name);

// 2. Find any loose photos directly in portugal/ (fallback if user hasn't sorted yet)
const looseFiles = entries
  .filter((e) => e.isFile() && isImage(e.name))
  .map((e) => e.name)
  .sort();

// 3. Build the list of city sections
type Section = { slug: string; title: string; photos: string[] };
const orderedSlugs = [
  ...cityOrder.filter((c) => subDirs.includes(c)),
  ...subDirs.filter((c) => !cityOrder.includes(c)).sort(),
];

const sections: Section[] = orderedSlugs.map((slug) => {
  const photos = fs
    .readdirSync(path.join(baseDir, slug))
    .filter(isImage)
    .sort()
    .map((f) => `/gallery/portugal/${slug}/${f}`);
  return { slug, title: prettify(slug), photos };
});
---
<BaseLayout
  title="Frames of Portugal, April 2025 — Behnaz"
  description="Photos and small memories from a wonderful trip to Portugal in April 2025."
>
  <section class="rise">
    <div class="page-head">
      <p class="eyebrow">Gallery · Travel</p>
      <h1>Portugal, April 2025</h1>
      <p class="lede">
        A slow week along the Portuguese coast, from the orange blossoms in the south to the seagles of the north — pastel-painted streets,
        ocean light that wouldn't sit still, the smell of grilled sardines
        drifting out of small kitchens, and the gentle clatter of trams
        going somewhere unhurried. These are the views I want to remember.
      </p>
      <p class="mt-3">
        <a href="/gallery" class="nav-link text-sm text-[color:var(--color-ink-soft)]">
          ← Back to gallery
        </a>
      </p>
    </div>

    {sections.length > 0 && (
      <nav class="city-nav" aria-label="Cities">
        {sections.map((s) => (
          <a href={`#${s.slug}`}>{s.title}</a>
        ))}
      </nav>
    )}

    {sections.map((s) => (
      <div class="city-section" id={s.slug}>
        <div class="index-group-title">
          <span>{s.title}</span>
          <span class="index-group-title-count">{s.photos.length} {s.photos.length === 1 ? "photo" : "photos"}</span>
        </div>
        <div class="photo-grid">
          {s.photos.map((src, i) => (
            <figure class="photo">
              <a href={src} target="_blank" rel="noopener">
                <img src={src} alt={`${s.title} photo ${i + 1}`} loading="lazy" />
              </a>
            </figure>
          ))}
        </div>
      </div>
    ))}

    {looseFiles.length > 0 && (
      <div class="city-section">
        <div class="index-group-title">
          <span>Unsorted</span>
          <span class="index-group-title-count">{looseFiles.length} photos · drag into a city folder to sort</span>
        </div>
        <div class="photo-grid">
          {looseFiles.map((f, i) => (
            <figure class="photo">
              <a href={`/gallery/portugal/${f}`} target="_blank" rel="noopener">
                <img src={`/gallery/portugal/${f}`} alt={`Portugal photo ${i + 1}`} loading="lazy" />
              </a>
            </figure>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .city-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.8rem;
    margin-bottom: 2rem;
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-soft);
    background: var(--color-paper);
    font-size: 0.85rem;
  }
  .city-nav a {
    color: var(--color-ink-soft);
    transition: color 0.16s ease;
  }
  .city-nav a:hover { color: var(--color-accent); }
  .city-nav a + a::before {
    content: "·";
    color: var(--color-ink-muted);
    margin-right: 0.8rem;
    margin-left: -0.4rem;
  }

  .city-section {
    margin-bottom: 2.5rem;
    scroll-margin-top: 1rem;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
  }
  @media (min-width: 720px) {
    .photo-grid { grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
  }
  .photo {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-soft);
    border: 1px solid var(--color-line);
    background: var(--color-card);
    aspect-ratio: 4 / 5;
  }
  .photo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .photo:hover img { transform: scale(1.03); }
</style>
