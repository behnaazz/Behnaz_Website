---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .sort((a, b) => b.data.year.localeCompare(a.data.year));

const byYear = new Map<string, typeof projects>();
for (const p of projects) {
  const y = p.data.year;
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = Array.from(byYear.keys()).sort((a, b) => b.localeCompare(a));
---
<BaseLayout
  title="Projects — Behnaz"
  description="Things I've built and worked on."
>
  <section class="rise">
    <div class="page-head">
      <p class="eyebrow">projects</p>
      <h1>Things I've Made</h1>
      <p class="lede">
        Research, code, and side experiments — usually somewhere between
        optics, machine learning, and a useful little tool. {projects.length} in total.
      </p>
    </div>

    {years.map((y) => (
      <div class="index-group">
        <div class="index-group-title">
          <span>{y}</span>
          <span class="index-group-title-count">{byYear.get(y)!.length} {byYear.get(y)!.length === 1 ? "project" : "projects"}</span>
        </div>
        <ul class="index-list">
          {byYear.get(y)!.map((p) => (
            <li>
              {p.data.link ? (
                <a class="index-row" href={p.data.link} target="_blank" rel="noopener">
                  <span class="index-date">{p.data.role ?? "—"}</span>
                  <span>
                    <span class="index-title">
                      {p.data.emoji && <span class="mr-1.5">{p.data.emoji}</span>}
                      {p.data.title}
                      <span class="ml-1.5 text-[color:var(--color-ink-muted)] text-sm">↗</span>
                    </span>
                    <span class="index-desc">{p.data.description}</span>
                    {p.data.stack.length > 0 && (
                      <span class="mt-2 flex flex-wrap gap-1.5">
                        {p.data.stack.map((s) => (
                          <span class="rounded-full border border-[color:var(--color-line)] bg-[color:var(--color-cream-warm)] px-2 py-0.5 text-[0.7rem]">
                            {s}
                          </span>
                        ))}
                      </span>
                    )}
                  </span>
                  <span class="index-meta">
                    {p.data.featured && <span class="tag tag-project">featured</span>}
                  </span>
                </a>
              ) : (
                <div class="index-row">
                  <span class="index-date">{p.data.role ?? "—"}</span>
                  <span>
                    <span class="index-title">
                      {p.data.emoji && <span class="mr-1.5">{p.data.emoji}</span>}
                      {p.data.title}
                    </span>
                    <span class="index-desc">{p.data.description}</span>
                    {p.data.stack.length > 0 && (
                      <span class="mt-2 flex flex-wrap gap-1.5">
                        {p.data.stack.map((s) => (
                          <span class="rounded-full border border-[color:var(--color-line)] bg-[color:var(--color-cream-warm)] px-2 py-0.5 text-[0.7rem]">
                            {s}
                          </span>
                        ))}
                      </span>
                    )}
                  </span>
                  <span class="index-meta">
                    {p.data.featured && <span class="tag tag-project">featured</span>}
                  </span>
                </div>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>
